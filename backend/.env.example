# === DATABASE ===
# "sqlite" = local file (backend/data/rio.db). Default. No setup needed.
# "supabase" = cloud Postgres. Requires SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY below.
DB_DRIVER=sqlite

# Supabase (server-side only — NEVER expose service_role to frontend or commit to git)
# Get these from your project at https://supabase.com → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ-paste-your-service-role-key-here

# === LLM PROVIDER ===
# Default provider when frontend doesn't specify one: openai | groq | gemini | github
LLM_PROVIDER=groq

