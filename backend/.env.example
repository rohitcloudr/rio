# Default provider when frontend doesn't specify one
LLM_PROVIDER=groq

# === API keys (set the ones you want; unconfigured providers won't show in UI) ===

# OpenAI — https://platform.openai.com/api-keys (paid only)
OPENAI_API_KEY=sk-paste-your-openai-key-here

# Groq — https://console.groq.com/keys (free, generous limits)
GROQ_API_KEY=gsk-paste-your-groq-key-here

# Google Gemini — https://aistudio.google.com/apikey (free, ~1M tokens/day)
GEMINI_API_KEY=paste-your-gemini-key-here

# GitHub Models — https://github.com/settings/tokens (free, ~50 requests/day)
# Generate a "Fine-grained personal access token" with no extra permissions, name it freely.
GITHUB_TOKEN=ghp-paste-your-github-pat-here

PORT=8787
